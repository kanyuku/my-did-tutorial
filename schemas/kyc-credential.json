{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KYC Credential Schema",
  "description": "Schema for privacy-preserving KYC verification.",
  "type": "object",
  "properties": {
    "countryCode": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2,
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "expiryDate": {
      "type": "integer",
      "description": "Date of expiry in YYYYMMDD format"
    },
    "idHash": {
      "type": "string",
      "description": "Hash of the identity document number (passport/ID)"
    }
  },
  "required": ["countryCode", "expiryDate", "idHash"]
}
